shared-workspace-lockfile=false

# Supply-chain hardening for pnpm 10.
# No minimum-release-age here: Fumapress/Waku/Fumadocs pull transitive deps (Takumi, Hono,
# lucide-react) that publish more often than the engine repos' 7-day gate. CI runs pnpm audit instead.
block-exotic-subdeps=true
strict-dep-builds=true
