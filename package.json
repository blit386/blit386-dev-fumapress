{
  "name": "blit386-dev-fumapress",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Documentation site for BLIT386 (blit386.dev), built with Fumapress, Waku, and Fumadocs.",
  "author": {
    "name": "Václav Vančura",
    "url": "https://github.com/vancura"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blit386/blit386-dev-fumapress.git"
  },
  "homepage": "https://blit386.dev",
  "bugs": {
    "url": "https://github.com/blit386/blit386-dev-fumapress/issues"
  },
  "keywords": [
    "blit386",
    "documentation",
    "fumadocs",
    "fumapress",
    "mdx",
    "technical-docs",
    "waku"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "yaml@>=2.0.0 <2.8.3": "^2.8.3",
      "fast-uri@>=3.0.0 <3.1.4": "^3.1.4",
      "sharp@<0.35.0": "^0.35.0",
      "@hono/node-server@>=2.0.0 <2.0.10": "^2.0.10"
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "waku dev",
    "build": "fumadocs-mdx && cross-env CLOUDFLARE=1 waku build",
    "postbuild": "node scripts/patch-wrangler.mjs && node scripts/patch-html-title.mjs",
    "start": "wrangler dev --config dist/server/wrangler.json",
    "typecheck": "fumadocs-mdx && tsc --noEmit",
    "types:check": "pnpm run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx,mdc,yml,yaml}\"",
    "format:check": "biome check . && prettier --check \"**/*.{md,mdx,mdc,yml,yaml}\"",
    "spellcheck": "cspell \"content/**/*.{md,mdx,mdc}\" \"src/**/*.{ts,tsx}\" \"*.{md,mdx,mdc}\" \"CLAUDE.md\" --no-progress",
    "docs:links": "node scripts/check-markdown-links.mjs",
    "sync:docs": "node scripts/sync-docs-from-engine.mjs",
    "sync:docs:check": "pnpm run sync:docs && git diff --exit-code -- content/docs",
    "sync:docs:watch": "node scripts/watch-engine-docs.mjs",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:audit:prod": "pnpm audit --prod --audit-level=moderate",
    "test": "node --test scripts/__tests__/*.test.mjs",
    "test:watch": "node --test --watch scripts/__tests__/*.test.mjs",
    "preflight": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run spellcheck && pnpm run knip && pnpm run docs:links && pnpm run build",
    "deploy": "wrangler deploy --config dist/server/wrangler.json --name blit386",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{md,mdx,mdc,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,md,mdx,mdc}": [
      "cspell --no-progress --no-must-find-files"
    ]
  },
  "dependencies": {
    "@fuma-translate/react": "^1.0.2",
    "fumadocs-core": "^16.11.4",
    "fumadocs-mdx": "^15.1.1",
    "fumadocs-ui": "^16.11.4",
    "fumapress": "0.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-server-dom-webpack": "^19.2.7",
    "waku": "1.0.0-beta.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "blit386": "^1.3.0",
    "cross-env": "^7.0.3",
    "cspell": "^10.0.1",
    "fumadocs-twoslash": "^3.3.0",
    "husky": "^9.1.7",
    "knip": "^6.26.0",
    "lint-staged": "^16.4.0",
    "markdown-link-check": "^3.14.2",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.110.0"
  }
}
